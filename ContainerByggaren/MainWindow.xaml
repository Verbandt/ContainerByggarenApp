<Window x:Class="ContainerByggaren.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContainerByggaren"
        mc:Ignorable="d"
        Title="MainWindow" Width="1400" Height="788" Background="{DynamicResource BackgroundBrush}">

    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Grid Width="1400" Height="788"  Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <!-- Main -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <!-- Left -->
                <ColumnDefinition Width="Auto"/>
                <!-- Center -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <!-- Right -->
            </Grid.ColumnDefinitions>
            
            <!-- Title -->
            <Label Grid.Row="0" Grid.Column="1" Content="ContainerByggaren" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"
                Background="{DynamicResource BackgroundBrush }" HorizontalAlignment="Center" Margin="0,10"/>
            
            <!-- Articles -->
            <DataGrid Grid.Row="1" Grid.Column="1" Margin="10" AutoGenerateColumns="True" HeadersVisibility="Column"
                Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
            
            <!-- Simulation settings -->
            


        </Grid>
    </Viewbox>
        
</Window>
